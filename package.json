{
  "name": "auralis",
  "version": "0.1.2",
  "description": "A foobar2000-inspired SoundCloud desktop client with deep customization.",
  "author": {
    "name": "Auralis Contributors",
    "email": "257272272+transparentlyok@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/transparentlyok/auralis.git"
  },
  "homepage": "https://github.com/transparentlyok/auralis#readme",
  "bugs": {
    "url": "https://github.com/transparentlyok/auralis/issues"
  },
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "discord-rpc": "^4.0.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.11",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.transparentlyok.auralis",
    "productName": "Auralis",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "package.json",
      "themes/**/*",
      "examples/**/*",
      "docs/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Audio"
    },
    "publish": {
      "provider": "github",
      "owner": "transparentlyok",
      "repo": "auralis"
    }
  }
}
